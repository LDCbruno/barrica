<%- include('../partials/header') %>

<div class="login-wrapper">
  <div class="login-box">
    <h2>Crear cuenta</h2>
    <input type="text" id="nombre" placeholder="Nombre">
    <input type="text" id="apellido" placeholder="Apellido">
    <input type="email" id="email" placeholder="Correo electrónico">
    <input type="password" id="password" placeholder="Contraseña">
    <p id="error-msg" style="color: #e74c3c; font-size: 13px; min-height: 18px; margin-bottom: 10px;"></p>
    <button onclick="validarRegistro()">Registrarse</button>
    <p style="margin-top: 16px; font-size: 13px; color: #888;">
      ¿Ya tenés cuenta? <a href="/login" style="color: #c8973a;">Iniciá sesión</a>
    </p>
  </div>
</div>

<script>
function validarRegistro() {
  const nombre = document.getElementById('nombre').value.trim();
  const apellido = document.getElementById('apellido').value.trim();
  const email = document.getElementById('email').value.trim();
  const password = document.getElementById('password').value.trim();
  const errorMsg = document.getElementById('error-msg');

  if (!nombre || !apellido || !email || !password) {
    errorMsg.textContent = 'Todos los campos son obligatorios.';
    return;
  }

  const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
  if (!emailRegex.test(email)) {
    errorMsg.textContent = 'El email no es válido.';
    return;
  }

  if (password.length < 8) {
    errorMsg.textContent = 'La contraseña debe tener al menos 8 caracteres.';
    return;
  }

  if (!/[a-zA-Z]/.test(password)) {
    errorMsg.textContent = 'La contraseña debe incluir al menos una letra.';
    return;
  }

  if (!/[0-9]/.test(password)) {
    errorMsg.textContent = 'La contraseña debe incluir al menos un número.';
    return;
  }

  if (!/[!@#$%^&*(),.?":{}|<>]/.test(password)) {
    errorMsg.textContent = 'La contraseña debe incluir al menos un carácter especial.';
    return;
  }

  const prohibidas = ['password', '1234', 'qwerty', 'barrica', nombre.toLowerCase()];
  for (const p of prohibidas) {
    if (password.toLowerCase().includes(p)) {
      errorMsg.textContent = 'La contraseña contiene una cadena no permitida.';
      return;
    }
  }

  if (password === email) {
    errorMsg.textContent = 'La contraseña no puede ser igual al email.';
    return;
  }

  errorMsg.textContent = '';
  alert('Registro exitoso');
}
</script>

<%- include('../partials/footer') %>